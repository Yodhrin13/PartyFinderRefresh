<Project Sdk="Dalamud.NET.Sdk/14.0.2">

    <PropertyGroup>
        <Version>0.1.0.0</Version>
        <Authors>Yod</Authors>
        <Description>Automatically refreshes your Party Finder listing on a configurable timer.</Description>
        <RootNamespace>PartyFinderRefresher</RootNamespace>
        <AssemblyName>PartyFinderRefresher</AssemblyName>
        <Platforms>x64</Platforms>
        <Configurations>Debug;Release</Configurations>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ECommons" Version="3.*" />
    </ItemGroup>

</Project>
